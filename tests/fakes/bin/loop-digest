#!/usr/bin/env bash
# Fake loop-digest --json (CONTRACT.md surface): one loop in implement, one
# pending mailbox message, no ADRs.
set -eu

if [ -n "${FAKE_CALL_LOG:-}" ]; then
  line="$(basename "$0")"
  if [ "$#" -gt 0 ]; then line="$line $*"; fi
  printf '%s\n' "$line" >>"$FAKE_CALL_LOG"
fi

cat <<'EOF'
{
  "contract_version": 1,
  "generated_at": "2026-06-10T00:00:00Z",
  "state": {
    "schema_version": 2,
    "updated_at": "2026-06-10T00:00:00Z",
    "loops": {
      "loop-demo": {"status": "implement", "branch": "loop/demo", "artifacts": []}
    }
  },
  "mailbox": {
    "pending": [
      {"file": "20260610-000000-web-to-coord.md", "from": "web", "to": "coord", "subject": "demo", "mtime": 1770000000}
    ],
    "processed_count": 3
  },
  "unpushed": [],
  "adrs": []
}
EOF
