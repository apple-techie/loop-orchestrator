#!/usr/bin/env bash
# Fake harness-registry CLI (CONTRACT.md surface). Knows 'claude' one-shot;
# 'pi' has no one-shot mode (exit 1 + empty stdout, per contract).
set -eu

if [ -n "${FAKE_CALL_LOG:-}" ]; then
  line="$(basename "$0")"
  if [ "$#" -gt 0 ]; then line="$line $*"; fi
  printf '%s\n' "$line" >>"$FAKE_CALL_LOG"
fi

case "${1:-}" in
  field)
    if [ "${2:-}" = "claude" ] && [ "${3:-}" = "oneshot_template" ]; then
      echo 'claude -p {prompt}'
    else
      exit 1
    fi
    ;;
  oneshot)
    case "${2:-}" in
      claude) echo 'claude -p {prompt}' ;;
      *) exit 1 ;;
    esac
    ;;
  roster)
    # Unstubbed = empty roster = today's behavior (governance pass-through).
    if [ -n "${FAKE_ROSTER_JSON:-}" ]; then
      printf '%s\n' "$FAKE_ROSTER_JSON"
    else
      printf '{"contract_version": 1, "harnesses": []}\n'
    fi
    ;;
  health)
    printf '%s\n' "${FAKE_HEALTH:-ok}"
    ;;
  *)
    exit 1
    ;;
esac
