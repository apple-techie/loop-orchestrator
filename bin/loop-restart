#!/usr/bin/env bash
# loop-restart — the ONLY sanctioned restart path for a PM-syncing loop daemon.
#
# `loop-engine restart` run from a fresh shell inherits THAT shell's env, so a
# per-loop secret (e.g. JIRA_*) that lived only in the original launch shell
# vanishes — the PM adapter then silently reports unavailable and pull/push
# become no-ops, so loop state goes stale invisibly. This wrapper makes the
# safe sequence the default: re-source the per-loop env, reinstall the code (so
# a running daemon picks up changes), restart, then ASSERT the configured PM
# adapter is actually live before exiting 0. (T0031 / B1)
#
# Usage:  loop-restart <session> [--project-root R]
#
# Env:
#   LOOP_SECRETS_DIR        dir holding <session>.env  (default: ~/.loop-secrets)
#   LOOP_RESTART_INSTALL_CMD  reinstall command, run in the project root
#                           (default: "make install-python"; e.g.
#                            "uv tool install --reinstall --from . loop-orchestrator")
#
# Exit: 0 only when the daemon was restarted AND every configured PM adapter is
# available; 1 on any failure (missing env with a PM adapter configured,
# reinstall/restart failure, or an adapter still unavailable after restart);
# 2 on a usage error.
set -euo pipefail

usage() {
  echo "usage: loop-restart <session> [--project-root R]" >&2
}

session=""
project_root="$PWD"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --project-root) project_root="${2:?--project-root needs a value}"; shift 2 ;;
    --project-root=*) project_root="${1#*=}"; shift ;;
    -h | --help) usage; exit 0 ;;
    --) shift; break ;;
    -*) echo "loop-restart: unknown option '$1'" >&2; usage; exit 2 ;;
    *)
      if [[ -z "$session" ]]; then
        session="$1"; shift
      else
        echo "loop-restart: unexpected argument '$1'" >&2; usage; exit 2
      fi
      ;;
  esac
done
[[ -n "$session" ]] || { usage; exit 2; }

# Adapter names this loop configures (engine.pm.adapters in lane-config.yaml +
# host override). Empty = no PM layer, so the env file is optional and the
# readiness assert is a no-op. Any read failure degrades to "none configured"
# exactly as the engine's own config loader does (absent/unparseable => []).
_configured_adapters() {
  python3 - "$1" <<'PY' 2>/dev/null || true
import os, socket, sys

try:
    import yaml
except Exception:
    sys.exit(0)  # no yaml -> cannot introspect; the engine would see none either

root = sys.argv[1]
host = socket.gethostname().split(".")[0]
names: list[str] = []
for fn in ("lane-config.yaml", f"lane-config.{host}.yaml"):
    try:
        with open(os.path.join(root, fn), encoding="utf-8") as fh:
            doc = yaml.safe_load(fh)
    except (OSError, yaml.YAMLError):
        continue
    if not isinstance(doc, dict):
        continue
    engine = doc.get("engine") if isinstance(doc.get("engine"), dict) else {}
    pm = engine.get("pm") if isinstance(engine.get("pm"), dict) else {}
    for entry in pm.get("adapters") or []:
        name = entry.get("name") if isinstance(entry, dict) else entry
        if isinstance(name, str) and name and name not in names:
            names.append(name)
print(" ".join(names))
PY
}

adapters="$(_configured_adapters "$project_root")"

# ── step 1: re-source the per-loop env ───────────────────────────────────────
secrets_dir="${LOOP_SECRETS_DIR:-$HOME/.loop-secrets}"
env_file="$secrets_dir/$session.env"
if [[ -f "$env_file" ]]; then
  set -a
  # shellcheck disable=SC1090
  . "$env_file"
  set +a
  echo "loop-restart: sourced env $env_file" >&2
elif [[ -n "$adapters" ]]; then
  echo "loop-restart: FATAL: env file '$env_file' is missing but this loop" \
    "configures PM adapter(s): $adapters." >&2
  echo "  Without it those adapters would be UNAVAILABLE and pull/push a silent" \
    "no-op. Create the env file (set -a; export JIRA_*; set +a) or remove the" \
    "adapter from engine.pm.adapters. Aborting BEFORE restart." >&2
  exit 1
else
  echo "loop-restart: no env file ($env_file) and no PM adapter configured —" \
    "continuing" >&2
fi

# ── step 2: reinstall so a running daemon picks up code changes ───────────────
# Reinstall from the LOOP-ORCHESTRATOR repo (where the package + Makefile live),
# NOT the session --project-root — that root may be a DIFFERENT repo the loop
# builds (e.g. an app with no `install-python` target), which made the reinstall
# fail for non-orchestrator sessions (F18). Resolve the orchestrator root from
# this script's own location (bin/loop-restart), symlink-aware; LOOP_ORCH_ROOT
# overrides.
_loop_restart_self_dir() {
  local src="${BASH_SOURCE[0]}" dir
  while [[ -h "$src" ]]; do
    dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
    src="$(readlink "$src")"; [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd
}
orch_root="${LOOP_ORCH_ROOT:-$(cd "$(_loop_restart_self_dir)/.." >/dev/null 2>&1 && pwd)}"
install_cmd="${LOOP_RESTART_INSTALL_CMD:-make install-python}"
echo "loop-restart: reinstalling ($install_cmd) in $orch_root" >&2
( cd "$orch_root" && eval "$install_cmd" ) || {
  echo "loop-restart: FATAL: reinstall failed ($install_cmd) in $orch_root" >&2
  exit 1
}

# Pre-restart daemon pid — the post-restart poll requires a DIFFERENT live pid (a
# genuine swap), not merely any fresh heartbeat: the OLD daemon can survive the
# restart's stop window and heartbeat through it, falsely passing readiness while
# still running stale code (observed: loop-restart printed OK, then `status`
# warned "running stale code").
pid_file="$project_root/.loop/sessions/$session/engine/engine.pid"
pre_pid="$(cat "$pid_file" 2>/dev/null || true)"

# ── step 3: restart the engine, then POLL for readiness (NON-BLOCKING) ────────
# `loop-engine restart` ends in Watch.run()'s blocking `while self._running`
# loop — it BECOMES the foreground daemon and never returns (F10/T0037). Running
# it synchronously hung the wrapper here forever, so the PM-assert below and the
# `exit 0` were unreachable for a real daemon. Background it instead, then poll
# `loop-engine status` until the daemon reports alive with a FRESH heartbeat
# before asserting PM readiness.
echo "loop-restart: restarting engine for session '$session' (background)" >&2
# Detach the daemon's stdio to a log file: it becomes the long-lived foreground
# daemon, so it must NOT keep this wrapper's stdout/stderr open (that would also
# defeat the poll below). Its log is dumped on any failure for diagnosis.
restart_log="$(mktemp -t "loop-restart-${session}.XXXXXX")"
loop-engine --project-root "$project_root" --session "$session" restart \
  >"$restart_log" 2>&1 &
restart_pid=$!

_dump_restart_log() { [[ -s "$restart_log" ]] && sed 's/^/  | /' "$restart_log" >&2 || true; }

# A genuine swap (stop the old daemon — which may be mid-cycle — then start the
# new one and wait for its first fresh heartbeat) routinely takes >30s, so the
# strict swap-confirmation needs real headroom; the old 30s false-passed only
# because it accepted the OLD daemon's heartbeat. Override with LOOP_RESTART_TIMEOUT.
restart_timeout="${LOOP_RESTART_TIMEOUT:-60}"
max_heartbeat="${LOOP_RESTART_MAX_HEARTBEAT:-15}"
ready=""
deadline=$((SECONDS + restart_timeout))
while ((SECONDS < deadline)); do
  # If the backgrounded restart exited before becoming a live daemon, a non-zero
  # exit is a real failure; a zero exit (e.g. a detaching restart) just means we
  # keep polling status for the now-separate daemon.
  if [[ -n "$restart_pid" ]] && ! kill -0 "$restart_pid" 2>/dev/null; then
    rc=0
    wait "$restart_pid" || rc=$?
    if ((rc != 0)); then
      echo "loop-restart: FATAL: loop-engine restart exited ($rc) before the daemon came up" >&2
      _dump_restart_log
      exit 1
    fi
    restart_pid=""  # reaped; stop checking liveness, keep polling status
  fi
  # Capture stderr too (2>&1) so the engine's "running stale code" warning is
  # visible to the freshness check below.
  status="$(loop-engine --project-root "$project_root" --session "$session" status 2>&1 || true)"
  if grep -Eq 'watch: alive \(pid [0-9]+, heartbeat [0-9]+s ago\)' <<<"$status"; then
    cur_pid="$(sed -E -n 's/.*watch: alive \(pid ([0-9]+),.*/\1/p' <<<"$status" | head -1)"
    age="$(sed -E -n 's/.*heartbeat ([0-9]+)s ago.*/\1/p' <<<"$status" | head -1)"
    # A CLEAN swap = alive + fresh heartbeat + a live pid that differs from the
    # pre-restart daemon + no stale-code warning. The pid-changed check is what
    # catches the racy case where the old daemon survives stop and heartbeats
    # through the window (its code is stale, so an OK there would be a lie).
    if [[ -n "$age" ]] && ((age <= max_heartbeat)) \
       && [[ -n "$cur_pid" && "$cur_pid" != "$pre_pid" ]] \
       && ! grep -q 'stale' <<<"$status"; then
      ready=1
      break
    fi
  fi
  sleep 0.5
done
if [[ -z "$ready" ]]; then
  echo "loop-restart: FATAL: daemon did not cleanly swap (new pid + fresh heartbeat," \
    "no stale-code warning) within ${restart_timeout}s — pre_pid=${pre_pid:-none}," \
    "last seen pid=${cur_pid:-none}" >&2
  _dump_restart_log
  exit 1
fi
echo "loop-restart: daemon swapped (pid ${pre_pid:-none} -> ${cur_pid}, heartbeat ${age}s ago)" >&2

# ── step 4: assert PM readiness ──────────────────────────────────────────────
# list-adapters reports each installed adapter's env-based availability; it takes
# no --project-root (availability is env-derived, not project-derived).
if [[ -z "$adapters" ]]; then
  echo "loop-restart: OK — daemon restarted (no PM adapter configured)" >&2
  exit 0
fi

listing="$(loop-pm list-adapters)" || {
  echo "loop-restart: FATAL: 'loop-pm list-adapters' failed after restart" >&2
  exit 1
}
unavailable=""
for adapter in $adapters; do
  if ! grep -Eq "^${adapter}[[:space:]]+available\b" <<<"$listing"; then
    unavailable+=" $adapter"
  fi
done
if [[ -n "$unavailable" ]]; then
  echo "loop-restart: FATAL: PM adapter(s)$unavailable NOT available after restart:" >&2
  echo "$listing" | sed 's/^/  /' >&2
  echo "  The daemon is up but PM sync would be a SILENT no-op (env likely not" \
    "sourced). Fix $env_file and re-run." >&2
  exit 1
fi
echo "loop-restart: OK — daemon restarted, PM adapter(s) available: $adapters" >&2
exit 0
